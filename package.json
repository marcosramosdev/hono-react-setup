{
	"name": "hono-react-setup",
	"scripts": {
		"dev": "concurrently \"bun run dev:server\" \"bun run dev:web\"",
		"dev:server": "bun run --hot server/index.ts",
		"dev:web": "cd web && bun run dev",
		"build": "bun build ./server/index.ts --outdir ./dist --target bun && cd web && bun run build",
		"start": "bun run ./dist/index.js"
	},
	"dependencies": {
		"@types/node": "^25.5.0",
		"hono": "^4.12.8",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@types/bun": "^1.3.11",
		"concurrently": "^9.2.1"
	}
}
